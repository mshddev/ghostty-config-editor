font-family = "MesloLGS NF"
font-size = 16
window-save-state = always

keybind = cmd+backslash=new_split:right
keybind = shift+cmd+backslash=new_split:down
keybind = cmd+[=unbind
keybind = cmd+]=unbind
keybind = ctrl+[=goto_split:previous
keybind = ctrl+]=goto_split:next
keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right
